{
  "name": "wordum",
  "version": "0.6.1",
  "private": true,
  "homepage": "https://github.com/besdar/wordum",
  "author": "Beskov Dmitry @besdar",
  "repository": "besdar/wordum",
  "license": "GPL-3.0-only",
  "scripts": {
    "lint:check": "eslint ./src && prettier src/ --check",
    "lint:fix": "eslint --fix ./src && prettier --write src/",
    "run-android": "react-native run-android",
    "start": "react-native start",
    "tests": "jest",
    "release:android": "cd android && ./gradlew assembleRelease",
    "types:check": "tsc",
    "generate-translations": "node scripts/lang-generating.js && npm run lint:fix",
    "align-deps": "rnx-align-deps --diff-mode allow-subset"
  },
  "dependencies": {
    "@dr.pogodin/react-native-fs": "^2.38.2",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-navigation/material-top-tabs": "^7.4.24",
    "@react-navigation/native": "^7.1.14",
    "@react-navigation/native-stack": "^7.14.12",
    "@vitalets/google-translate-api": "^9.2.1",
    "expo": "^55.0.19",
    "expo-speech": "^55.0.13",
    "i18next": "^25.7.4",
    "intl-pluralrules": "^2.0.1",
    "react": "19.2.0",
    "react-hook-form": "^7.74.0",
    "react-i18next": "^16.6.6",
    "react-native": "0.83.9",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-localize": "^3.6.1",
    "react-native-pager-view": "8.0.0",
    "react-native-paper": "~5.15.1",
    "react-native-screens": "~4.24.0",
    "react-native-sound-player": "^0.14.5",
    "react-native-vector-icons": "^10.3.0",
    "reverso-api": "git+https://github.com/besdar/reverso-api.git#common",
    "ts-fsrs": "^5.3.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-typescript": "^7.25.9",
    "@babel/runtime": "^7.25.9",
    "@react-native-community/cli": "^20.1.3",
    "@react-native-community/cli-platform-android": "^20.0.0",
    "@react-native-community/cli-platform-ios": "^20.0.0",
    "@react-native/babel-preset": "^0.83.9",
    "@react-native/eslint-config": "^0.83.9",
    "@react-native/metro-config": "^0.83.9",
    "@react-native/typescript-config": "^0.81.6",
    "@rnx-kit/align-deps": "^3.4.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.2.1",
    "@types/react": "19.2.0",
    "babel-preset-expo": "^55.0.19",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-testing-library": "^7.16.2",
    "jest": "^29.2.1",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.22.2"
  },
  "rnx-kit": {
    "kitType": "app",
    "alignDeps": {
      "requirements": [
        "react-native@0.83"
      ],
      "capabilities": [
        "babel-preset-react-native",
        "community/cli",
        "community/cli-android",
        "community/cli-ios",
        "core",
        "core-android",
        "core-ios",
        "core/metro-config",
        "gestures",
        "jest",
        "navigation/native",
        "react",
        "screens",
        "storage"
      ]
    }
  }
}
