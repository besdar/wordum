{
  "name": "wordum",
  "version": "0.8.0",
  "main": "index.js",
  "private": true,
  "homepage": "https://github.com/besdar/wordum",
  "author": "Beskov Dmitry @besdar",
  "repository": "besdar/wordum",
  "license": "GPL-3.0-only",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint:check": "eslint ./src && prettier src/ --check",
    "lint:fix": "eslint --fix ./src && prettier --write src/",
    "run-android": "expo run:android",
    "tests": "jest",
    "release:android": "cd android && ./gradlew assembleRelease",
    "types:check": "tsc",
    "generate-translations": "node scripts/lang-generating.js && npm run lint:fix",
    "align-deps": "rnx-align-deps --diff-mode allow-subset"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/material-top-tabs": "^7.4.28",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "@vitalets/google-translate-api": "^9.2.1",
    "expo": "~56.0.8",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-localization": "~56.0.6",
    "expo-sharing": "~56.0.15",
    "expo-speech": "~56.0.3",
    "i18next": "^26.3.0",
    "intl-pluralrules": "^2.0.1",
    "react": "19.2.3",
    "react-hook-form": "^7.77.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-pager-view": "8.0.1",
    "react-native-paper": "^5.15.2",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "reverso-api": "git+https://github.com/besdar/reverso-api.git#common",
    "ts-fsrs": "^5.4.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@feature-sliced/eslint-config": "^0.1.1",
    "@react-native-community/cli": "^20.1.3",
    "@react-native-community/cli-platform-android": "^20.1.3",
    "@react-native-community/cli-platform-ios": "^20.1.3",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "^0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@rnx-kit/align-deps": "^4.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "~56.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-testing-library": "^7.16.2",
    "jest": "~29.7.0",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=22.22.2"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@notifee/react-native"
        ]
      }
    }
  },
  "rnx-kit": {
    "kitType": "app",
    "alignDeps": {
      "requirements": [
        "react-native@0.85"
      ],
      "capabilities": [
        "babel-preset-react-native",
        "community/cli",
        "community/cli-android",
        "community/cli-ios",
        "core",
        "core-android",
        "core-ios",
        "core/metro-config",
        "gestures",
        "jest",
        "navigation/native",
        "react",
        "screens",
        "storage"
      ]
    }
  }
}
